    {
      "name": "1c62f149",
      "displayName": "Model Performance Table",
      "queryLines": [
        "SELECT \n",
        "  Model,\n",
        "  COALESCE(CAST(Accuracy AS STRING), '-') AS Accuracy,\n",
        "  COALESCE(CAST(AUC_ROC AS STRING), '-') AS AUC_ROC,\n",
        "  Type\n",
        "FROM capstone_project.dashboard_metrics"
      ]
    },
    {
      "name": "200d54f6",
      "displayName": "Confusion Matrix Query",
      "queryLines": [
        "SELECT \n",
        "  CASE WHEN delay_risk_probability >= 0.14 THEN 'Predicted: High Risk' \n",
        "       ELSE 'Predicted: Low Risk' END AS Predicted, 'Actual: On-Time' AS Actual, COUNT(*) AS Total_Incidents\n",
        "FROM capstone_project.dashboard_predictions_nyc\n",
        "GROUP BY 1, 2\n",
        "ORDER BY 1, 2"
      ]
    },
    {
      "name": "77c729de",
      "displayName": "Feature Importance Chart",
      "queryLines": [
        "SELECT Feature, Hazard_Ratio \n",
        "FROM capstone_project.dashboard_hazard_ratios\n",
        "ORDER BY Hazard_Ratio ASC"
      ]
    },
    {
      "name": "f7187b31",
      "displayName": "Risk Distribution Histogram",
      "queryLines": [
        "SELECT delay_risk_probability \n",
        "FROM capstone_project.dashboard_predictions_nyc"
      ]
    }
