    {
      "name": "ac05473d",
      "displayName": "combined_model_ready",
      "queryLines": [
        "SELECT * FROM workspace.capstone_project.combined_model_ready\r\n",
        "-- SELECT DISTINCT city\r\n",
        "-- FROM workspace.capstone_project.combined_model_ready\r\n",
        "-- ORDER BY city"
      ],
      "columns": [
        {
          "displayName": "hazard_ratio",
          "description": "Hazard ratio for each city: compares delay_indicator (events) to event_indicator (total at-risk incidents).",
          "expression": "TRY_DIVIDE(SUM(delay_indicator), SUM(event_indicator))"
        }
      ]
    },
    {
      "name": "268ebafb",
      "displayName": "Median Response Time by City",
      "queryLines": [
        "SELECT\n",
        "  city,\n",
        "  APPROX_PERCENTILE(response_minutes, 0.5) AS median_response_time\n",
        "FROM\n",
        "  workspace.capstone_project.combined_model_ready\n",
        "GROUP BY\n",
        "  city"
      ],
      "catalog": "workspace",
      "schema": "capstone_project"
    },
    {
      "name": "50688811",
      "displayName": "mean_med_p90_p95",
      "queryLines": [
        "SELECT\r\n",
        "    city,\r\n",
        "    AVG(response_minutes) AS mean_response,\r\n",
        "    percentile_approx(response_minutes, 0.5) AS median_response,\r\n",
        "    percentile_approx(response_minutes, 0.9) AS p90_response,\r\n",
        "    percentile_approx(response_minutes, 0.95) AS p95_response\r\n",
        "FROM workspace.capstone_project.combined_model_ready\r\n",
        "GROUP BY city\r\n",
        "ORDER BY city"
      ]
    }
  ],
